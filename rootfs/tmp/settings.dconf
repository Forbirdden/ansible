[org/gnome/control-center]
last-panel='network'
window-state=(980, 640, false)


[org/gnome/desktop/app-folders/folders/Pardus]
categories=['X-Pardus-Apps']
name='X-Pardus-Apps.directory'
translate=true

[org/gnome/desktop/app-folders/folders/System]
apps=['org.freedesktop.MalcontentControl.desktop']
name='X-GNOME-Shell-System.directory'
translate=true

[org/gnome/desktop/app-folders/folders/Utilities]
name='X-GNOME-Shell-Utilities.directory'
translate=true

[org/gnome/desktop/break-reminders/eyesight]
play-sound=true

[org/gnome/desktop/break-reminders/movement]
duration-seconds=uint32 300
interval-seconds=uint32 1800
play-sound=true

[org/gnome/desktop/input-sources]
mru-sources=[('xkb', 'us'), ('xkb', 'ru')]
sources=[('xkb', 'us'), ('xkb', 'ru')]
xkb-options=['grp:alt_shift_toggle']

[org/gnome/desktop/notifications]
application-children=['org-gnome-shell-extensions-gsconnect', 'org-gnome-software', 'io-missioncenter-missioncenter']

[org/gnome/desktop/notifications/application/io-missioncenter-missioncenter]
application-id='io.missioncenter.MissionCenter.desktop'

[org/gnome/desktop/notifications/application/org-gnome-shell-extensions-gsconnect]
application-id='org.gnome.Shell.Extensions.GSConnect.desktop'

[org/gnome/desktop/notifications/application/org-gnome-software]
application-id='org.gnome.Software.desktop'

[org/gnome/desktop/peripherals/touchpad]
two-finger-scrolling-enabled=true

[org/gnome/desktop/search-providers]
sort-order=['org.gnome.Settings.desktop', 'org.gnome.Contacts.desktop', 'org.gnome.Nautilus.desktop']

[org/gnome/desktop/wm/preferences]
button-layout='appmenu:minimize,maximize,close'

[org/gnome/mutter]
overlay-key='Super_L'

[org/gnome/nautilus/preferences]
migrated-gtk-settings=true

[org/gnome/settings-daemon/plugins/color]
night-light-schedule-automatic=false

[org/gnome/shell]
app-picker-layout=[{'org.gnome.Terminal.desktop': <{'position': <0>}>, 'nemo.desktop': <{'position': <1>}>, 'com.discordapp.Discord.desktop': <{'position': <2>}>, 'gparted.desktop': <{'position': <3>}>, 'org.gnome.Settings.desktop': <{'position': <4>}>, 'System': <{'position': <5>}>, 'org.gnome.Tour.desktop': <{'position': <6>}>}]
enabled-extensions=['arcmenu@arcmenu.com', 'gsconnect@andyholmes.github.io', 'appindicatorsupport@rgcjonas.gmail.com', 'dash-to-panel@jderose9.github.com', 'blur-my-shell@aunetx', 'gtk4-ding@smedius.gitlab.com']
welcome-dialog-last-shown-version='49.5'

[org/gnome/shell/extensions/arcmenu]
application-shortcuts=[{'id': 'org.gnome.Settings.desktop'}, {'id': 'org.gnome.tweaks.desktop', 'name': 'Gnome Tweaks'}, {'id': 'com.mattjakeman.ExtensionManager.desktop', 'name': 'Расширения'}, {'name': 'Разделитель', 'icon': 'list-remove-symbolic', 'id': 'ArcMenu_Separator'}, {'id': 'org.gnome.Terminal.desktop'}, {'id': 'nemo.desktop'}]
context-menu-items=[{'id': 'ArcMenu_Settings', 'name': 'ArcMenu Settings', 'icon': 'ArcMenu_ArcMenuIcon'}, {'id': 'ArcMenu_PanelExtensionSettings', 'name': 'Panel Extension Settings', 'icon': 'application-x-addon-symbolic'}, {'id': 'ArcMenu_Separator', 'name': 'Separator', 'icon': 'list-remove-symbolic'}, {'id': 'io.missioncenter.MissionCenter.desktop'}]
menu-background-color='rgb(245,247,250)'
menu-border-color='rgba(18,51,84,0.2)'
menu-button-icon='resource:///org/gnome/shell/extensions/arcmenu/icons/scalable/actions/distro-fedora-symbolic.svg'
menu-button-icon-size=35
menu-foreground-color='rgb(18,51,84)'
menu-item-active-bg-color='rgba(18,51,84,0.15)'
menu-item-active-fg-color='rgb(18,51,84)'
menu-item-hover-bg-color='rgba(18,51,84,0.08)'
menu-item-hover-fg-color='rgb(18,51,84)'
menu-separator-color='rgba(18,51,84,0.15)'
override-menu-theme=true
pinned-apps=[{'id': 'org.gnome.Terminal.desktop'}, {'id': 'com.discordapp.Discord.desktop'}, {'id': 'com.google.Chrome.desktop'}, {'id': 'org.vinegarhq.Sober.desktop'}]
